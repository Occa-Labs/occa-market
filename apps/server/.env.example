# apps/server environment. Copy to .env and fill in.
# Validated at boot by src/config/env.ts — unknown-but-missing optional vars fall back to these defaults.

# Postgres connection string. Required. The repository reads the catalog from here.
DATABASE_URL=postgres://user:password@localhost:5432/occa_market

# HTTP port the API listens on.
PORT=4000

# Comma-separated web origins allowed by CORS.
CORS_ORIGIN=http://localhost:3000

# Real agent replies call the Claude API. Without a key the server falls back
# to canned MockRuntime replies (demo only).
ANTHROPIC_API_KEY=

# Runtime model + token budget for LLMRuntime.
RUNTIME_MODEL=claude-opus-4-8
RUNTIME_MAX_TOKENS=1024

# ── $OCCA holder gating (agent-marketplace-token.md) ─────────────────────────
# USDC pays, $OCCA unlocks: holding ≥0.1% of supply is the membership line that
# unlocks the free weekly message budget and publishing; higher tiers raise the
# budget (token doc §4). Gates enforce only when TOKEN_GATE_ENABLED=1 — with 0
# the standing endpoint still works (badge + meter render) but chat/publish
# stay open, so local dev needs no holdings.
TOKEN_GATE_ENABLED=0

# The $OCCA mint (mainnet, pump.fun) and the RPC used to read balances. The
# public mainnet endpoint rate-limits token queries hard — use a dedicated
# (e.g. Alchemy) mainnet key for anything beyond local poking. Server-side key,
# NOT the origin-whitelisted frontend one.
TOKEN_MINT=GYSHDDoVtFNdzR72SSkmJcKWFVh9ndhMdYoDKdg8pump
TOKEN_RPC_URL=https://api.mainnet-beta.solana.com

# Tier thresholds are percentages of this fixed basis (1B pump.fun supply), so
# 0.1% = 1,000,000 tokens. Burns shrink live supply, not the thresholds.
TOKEN_TOTAL_SUPPLY=1000000000

# How long a balance snapshot stays fresh (ms) before standing re-reads the
# chain. Snapshots also serve as the fallback when the RPC is down.
TOKEN_CACHE_TTL_MS=600000

# Dev/admin wallets (CSV) — unmetered, bypass hold + budget gates server-side.
DEV_WALLETS=

# Comma-separated agent ids that are LIVE in this build. Everything else shows
# "coming soon". Replaces the old hardcoded isAvailable() degen-scout check.
ALLOWED_AGENTS=degen-scout

# Wall-clock budget (ms) for one gateway run before it's stopped. Tool-heavy
# turns (OHLCV pulls, transaction tapes) routinely pass 2 minutes.
GATEWAY_RUN_TIMEOUT_MS=300000

# Auth. JWT_SECRET signs our own 24h session token — REQUIRED, boot fails without it.
# Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Privy app credentials (dashboard.privy.io). Optional — the app boots without
# them, but POST /api/auth/privy errors until they're set.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# GitHub PAT for skill import (POST /api/agents/skills/import). Optional, but
# anon GitHub API is 60 req/hr — a token raises it to 5000. Fine-grained token
# with public-repo read is enough. Create at github.com/settings/tokens.
GITHUB_TOKEN=

# Paid-usage credits (USDC on mainnet, read via TOKEN_RPC_URL). Deposits stay
# disabled until the market's receiving wallet is set. USDC_MINT defaults to
# mainnet USDC; override only for testing.
DEPOSIT_WALLET=

# x402 machine rail (pay-per-request, POST /api/x402/agents/:id/messages).
# Activates with DEPOSIT_WALLET — payments land in the same wallet. Defaults:
# PayAI facilitator + Solana mainnet (CAIP-2). For devnet testing set
# X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1 and a devnet USDC_MINT.
X402_FACILITATOR_URL=
X402_NETWORK=
