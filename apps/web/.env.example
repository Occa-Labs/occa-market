# apps/web environment. Copy to .env.local for dev.

# Base URL of the API server (apps/server). Used both server-side (RSC fetch)
# and client-side, so it must be NEXT_PUBLIC_*.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Display-only welcome credit the chat seeds (blueprint §6.1). The server holds
# the source-of-truth value for the future credit ledger.
NEXT_PUBLIC_WELCOME_CREDIT=0.5

# Privy app id (dashboard.privy.io) — public, used by the browser SDK. Empty
# disables the sign-in button gracefully.
NEXT_PUBLIC_PRIVY_APP_ID=

# Dev/admin wallets (CSV) — signed-in users with these wallets bypass the chat
# credit gate. Display-only until the server-side ledger lands. Empty = nobody.
NEXT_PUBLIC_DEV_WALLETS=
